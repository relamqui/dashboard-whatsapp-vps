# .env.example — Variáveis de Ambiente para Produção
# Copie este arquivo para .env e preencha os valores

# Segredo JWT (use uma string longa e aleatória)
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE

# Configurações do PostgreSQL (para uso local com docker-compose)
POSTGRES_DB=wpcrm
POSTGRES_USER=wpcrm_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# URL da Evolution API
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com

# Chave da Evolution API
EVOLUTION_API_KEY=sua_chave_aqui

# Porta exposta (opcional, padrão 3008)
APP_PORT=3008

# Credenciais do Administrador Padrão (Criado no primeiro acesso se o banco estiver vazio)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123
